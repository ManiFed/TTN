{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "venv/bin/python3",
      "runtimeArgs": ["src/dashboard.py"],
      "port": 5173
    },
    {
      "name": "website",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4187", "--directory", "website"],
