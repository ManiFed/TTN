FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir --upgrade pip

COPY cloud/requirements.txt cloud/requirements.txt
RUN pip install --no-cache-dir -r cloud/requirements.txt

COPY cloud/ cloud/
COPY src/ src/
COPY website/ website/

RUN mkdir -p /app/cloud_data/aavso_batches /app/cloud_data/raw_images

ENV PYTHONUNBUFFERED=1

EXPOSE ${PORT:-8800}

CMD ["python", "-m", "cloud.main", "cloud/config.production.yaml"]
